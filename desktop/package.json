{
  "name": "echolog-desktop",
  "private": true,
  "version": "0.4.0",
  "description": "echolog 桌面 GUI - 浏览日记 / 选题 / 配置 / 状态",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "package": "npm run build && electron-builder --mac",
    "package:dir": "npm run build && electron-builder --mac --dir",
    "package:dmg": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "rehype-highlight": "^7.0.0",
    "highlight.js": "^11.10.0",
    "lucide-react": "^0.456.0",
    "dayjs": "^1.11.13",
    "electron-updater": "^6.3.9",
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.52.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^22.9.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "electron-builder": "^25.1.8",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5",
    "@testing-library/react": "^16.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/dom": "^10.4.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^3.4.15",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
