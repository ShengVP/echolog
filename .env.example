# ===========================================================================
# 你是谁（决定 diary / 选题怎么写；不填也能跑，但会用「中性」voice，效果一般）
# ---------------------------------------------------------------------------
# 这几个变量会注入 prompts/diary_*.md 模板 + drafts.js 的 SHARED_VOICE
# 改完 echolog restart 立即生效
# ===========================================================================
# USER_NAME=你的名字或昵称
# USER_IDENTITY=独立开发者 / 创业者 / 学生 / 产品经理 / 工程师 ...（一句话身份描述）
# USER_PROJECTS=你正在做的项目名（多个用顿号；例：[[侧项目A]]、[[博客]]）
# USER_CONTENT_FOCUS=真实创业暴露 + AI 实操 + 工程师家庭日常（你想沉淀什么内容主题）
# USER_TONE_HINT=克制理性、有距离感、重证据、不鸡汤（你希望 diary 用什么语气）

# ===========================================================================
# 飞书 / Lark 私密日记 bot（必填）
# 开放平台 → 你的应用 → 凭证与基础信息
# ===========================================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================================================
# Telegram bot（可选，仅当你也想跑 TG 通道时填）
# https://t.me/BotFather → /newbot → 拿 token；自己的 numeric user id 可以问 @userinfobot
# ===========================================================================
# TG_BOT_TOKEN=12345:ABCDEF...
# TG_OWNER_ID=123456789
# TG_PROXY_URL=http://127.0.0.1:7897   # 大陆访问 TG 必须走代理；可改成你的实际代理地址

# ===========================================================================
# 滴答清单 / TickTick OpenAPI（可选）
# https://developer.dida365.com/manage → 创建应用 → 拿到 ID + Secret
# Redirect URI 一定要填 http://127.0.0.1:8765/callback（OAuth 本地回调）
# 配好后在终端执行：echolog ticktick-auth 完成一次性授权
# ===========================================================================
# TICKTICK_CLIENT_ID=xxxxxxxxxxxxxxxxxx
# TICKTICK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 任务路由（可选）：
#   不设 / 留空 → 任务和选题都进 Notes 项目（kind: NOTE，不污染 Today 视图，无 dueDate）
#   设为 'inbox' → 任务进默认 Inbox（仍无 dueDate）
#   设为某个具体 project_id → 任务进那个项目
# TICKTICK_TASKS_PROJECT_ID=

# ===========================================================================
# LLM Provider — 决定 /diary、/draft、/recall、/week 等命令用哪个大模型
# ---------------------------------------------------------------------------
# LLM_PROVIDER=ollama       本地 Ollama（默认）—— 数据完全不出本机，但需要 16GB+ 内存才能跑 9B 文本模型
# LLM_PROVIDER=openai       走 OpenAI 兼容协议（DeepSeek / Moonshot / OpenAI / 智谱 / OpenRouter / MiniMax / 自建 vLLM 都兼容）
# LLM_PROVIDER=anthropic    走 Anthropic 原生 Messages API（Claude）—— 文本 + 图片同一个模型
# ===========================================================================
# LLM_PROVIDER=ollama

# --- 云端 provider 时必填（LLM_PROVIDER=openai 时）---
# DeepSeek（中国用户首选，价格极低 ≈ ¥0.001/1K token，写中文质量好）:
#   LLM_API_BASE=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
#   LLM_TEXT_MODEL=deepseek-chat
#
# Moonshot Kimi（中国用户次选）:
#   LLM_API_BASE=https://api.moonshot.cn/v1
#   LLM_TEXT_MODEL=moonshot-v1-8k
#
# OpenAI:
#   LLM_API_BASE=https://api.openai.com/v1
#   LLM_TEXT_MODEL=gpt-4o-mini
#
# OpenRouter（可接 Claude / Gemini / 任何模型）:
#   LLM_API_BASE=https://openrouter.ai/api/v1
#   LLM_TEXT_MODEL=anthropic/claude-3.5-sonnet
#
# MiniMax（国内，多模态 M3 很强；文本+图片可共用一个模型）:
#   LLM_API_BASE=https://api.minimaxi.com/v1
#   LLM_TEXT_MODEL=MiniMax-M3
#   LLM_VISION_MODEL=MiniMax-M3
# LLM_API_BASE=
# LLM_API_KEY=

# --- Anthropic 原生（LLM_PROVIDER=anthropic 时）---
# Claude 写中文日记质量很高；Sonnet 性价比最好，文本+图片共用一个模型即可：
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-xxxxxxxx
#   LLM_TEXT_MODEL=claude-sonnet-4-6        # 文本：日记/选题/周报（也支持视觉）
#   LLM_VISION_MODEL=claude-sonnet-4-6      # 视觉：解析图片（同一个模型即可）
#   # 想要最强可换 claude-opus-4-8（更贵）；注意 Opus 4.7/4.8 不接受 temperature，已自动处理
# 说明：
#   - 思考默认就是关的（不会输出 <think>），无需设 LLM_DISABLE_THINKING
#   - LLM_API_BASE 可省（默认 https://api.anthropic.com），仅走代理/网关时填
#   - Anthropic 没有 embedding API：要用 /recall 跨日检索，把 EMBEDDINGS 留给 ollama，
#     或关掉 ENABLE_EMBEDDINGS=false

# 关闭推理模型（MiniMax-M3 / DeepSeek-R1 等）的思考过程，输出更干净、更快、更省 token
# 走官方参数 thinking:{type:disabled}，不在 content 里正则剥 <think>
# LLM_DISABLE_THINKING=true

# --- 模型名（不设的话 fallback 到下方 OLLAMA_* 默认值，即本地 ollama 模型）---
# LLM_TEXT_MODEL=deepseek-chat                          # 文本：写日记 / 选题 / 周报 / self-review
# LLM_VISION_MODEL=gpt-4o-mini                          # 视觉：解析图片（OpenAI Vision 协议）
# LLM_EMBED_MODEL=text-embedding-3-small                # Embedding：跨日记忆 /recall

# ===========================================================================
# Ollama 本地模型（向后兼容；LLM_PROVIDER=ollama 时生效）
# ===========================================================================
# OLLAMA_TEXT_MODEL=qwen3.5:9b
# OLLAMA_VISION_MODEL=openbmb/minicpm-o2.6:latest
# OLLAMA_EMBED_MODEL=bge-large:335m              # 跨日记忆 / /recall 用；可换成 qwen3-embedding:4b（更准但慢）

# ===========================================================================
# 功能开关（true / false，缺省都是 true 即启用）
# ---------------------------------------------------------------------------
# 不是所有用户都需要全套功能。关掉用不到的模块让 bot 更轻：
# ===========================================================================
# ENABLE_TICKTICK=true       关掉则 /diary 不拉任务上下文 + 不同步 action items + /tasks /todo 命令禁用
# ENABLE_DRAFTS=true         关掉则 /draft 命令禁用（diary 模板里的「选题」段需要自己改 prompt 移除）
# ENABLE_URL_ENRICH=true     关掉则发链接时不再自动抓 og title/description
# ENABLE_ASR=true            关掉则收语音只存档，不调 whisper 转文字
# ENABLE_EMBEDDINGS=true     关掉则 /diary 不异步索引 + /recall 命令禁用

# ===========================================================================
# 周报范围配置
# ---------------------------------------------------------------------------
# 周报从 (今天 + WEEKLY_RANGE_END_OFFSET) 开始，往前数 WEEKLY_RANGE_DAYS 天
# 例：默认 (7 + 0) → 今天前 7 天
# 例：(5 + 0) → 今天前 5 天（工作日感）
# 例：(7 + -1) → 截至昨天前 7 天
# 例：(14 + 0) → 双周报
# ===========================================================================
# WEEKLY_RANGE_DAYS=7
# WEEKLY_RANGE_END_OFFSET=0

# ===========================================================================
# Prompt 版本管理（v0.4+）
# 8 个 prompt 都可以独立切版本。改完 echolog restart 立即生效。
# 用 echolog prompt 命令查看；也可以在桌面 GUI 的「Prompt 编辑」视图里改/新建
# 不设这些变量都用默认 v1（每个 prompt 都保证有 v1 baseline）
# ===========================================================================
# DIARY_PROMPT_VERSION=v1                  /diary 日记
# WEEKLY_PROMPT_VERSION=v1                 /week 周报
# DRAFTS_TWITTER_PROMPT_VERSION=v1         /draft <id>          推特串
# DRAFTS_LONG_PROMPT_VERSION=v1            /draft <id> --long   公众号长文
# DRAFTS_VIDEO_PROMPT_VERSION=v1           /draft <id> --video  短视频脚本
# SELF_REVIEW_SINGLE_PROMPT_VERSION=v1     echolog self-review 的单日审稿
# SELF_REVIEW_ADVICE_PROMPT_VERSION=v1     echolog self-review 末尾的 prompt 建议
# VISION_DESCRIBE_PROMPT_VERSION=v1        视觉模型解析图片用

# ===========================================================================
# HTTP /ingest 端点（可选，让 Android Tasker / HTTP Shortcuts 灌入内容）
# 必须 ≥16 字符随机串。生成方法：openssl rand -hex 24
# 不设此变量则 ingest server 不启动。详见 docs/XIAOMI_INTEGRATION.md
# ===========================================================================
# INGEST_TOKEN=
# INGEST_PORT=8766
